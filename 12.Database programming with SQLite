//*********************************DBHelper.kt 
package com.example.myapplication 
import android.content.ContentValues 
import android.content.Context 
import android.database.sqlite.SQLiteDatabase 
import android.database.sqlite.SQLiteOpenHelper 
class DBHelper(context: Context) : 
SQLiteOpenHelper(context, "StudentDB", null, 1) { 
override fun onCreate(db: SQLiteDatabase) { 
db.execSQL( 
"CREATE TABLE Student(id INTEGER PRIMARY KEY AUTOINCREMENT, name 
TEXT, age INTEGER)" 
) 
} 
override fun onUpgrade(db: SQLiteDatabase, oldVersion: Int, newVersion: Int) { 
db.execSQL("DROP TABLE IF EXISTS Student") 
onCreate(db) 
} 
fun insertData(name: String, age: String): Boolean { 
val db = this.writableDatabase 
val contentValues = ContentValues() 
contentValues.put("name", name) 
contentValues.put("age", age) 
val result = db.insert("Student", null, contentValues) 
return result != -1L 
} 
fun deleteData(name: String): Boolean { 
val db = this.writableDatabase 
val result = db.delete("Student", "name=?", arrayOf(name)) 
return result > 0 
} 
fun getAllData(): String { 
val db = this.readableDatabase 
val cursor = db.rawQuery("SELECT * FROM Student", null) 
var data = "" 
if (cursor.moveToFirst()) { 
do { 
data += "ID: ${cursor.getInt(0)}\n" 
data += "Name: ${cursor.getString(1)}\n" 
data += "Age: ${cursor.getInt(2)}\n\n" 
} while (cursor.moveToNext()) 
} 
cursor.close() 
return data 
} 
} 
